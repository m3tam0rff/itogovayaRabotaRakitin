<Window x:Class="TradeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeApp"
        mc:Ignorable="d"
        Title="Терминал Trade - Просмотр товаров"
        Height="450" Width="800"
        Background="{StaticResource MainBackgroundBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="КНИЖНЫЙ ТЕРМИНАЛ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtCountInfo" Text="0 из 0" Foreground="White" Margin="0,0,15,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <Button x:Name="BtnViewOrder" Content="Просмотр заказа" Padding="10,4" Margin="0,0,15,0" Background="#666666" Visibility="Collapsed" Click="BtnViewOrder_Click"/>
                        <TextBlock x:Name="TxtUserFIO" Text="Гость" Foreground="White" Margin="0,0,15,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <Button x:Name="BtnAuthAction" Content="Войти" Padding="10,4" Click="BtnAuthAction_Click"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Поиск по названию:" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="TbSearch" Width="150" Padding="3" TextChanged="FilterChanged"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Производитель:" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CbManufacturers" Width="140" DisplayMemberPath="Name" SelectionChanged="FilterChanged"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Цена от:" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="TbMinPrice" Width="60" Padding="3" TextChanged="FilterChanged"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Цена до:" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="TbMaxPrice" Width="60" Padding="3" TextChanged="FilterChanged"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Сортировка:" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CbSorting" Width="140" SelectionChanged="FilterChanged">
                            <ComboBoxItem Content="Без сортировки"/>
                            <ComboBoxItem Content="Цена: по возрастанию"/>
                            <ComboBoxItem Content="Цена: по убыванию"/>
                            <ComboBoxItem Content="Название: А-Я"/>
                            <ComboBoxItem Content="Название: Я-А"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ListView Grid.Row="1" x:Name="LvProducts" HorizontalContentAlignment="Stretch" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,12" Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#555555" Margin="0,0,0,10" FontSize="13" LineHeight="18"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Производитель: " Foreground="#777777" FontSize="12"/>
                                    <TextBlock Text="{Binding Manufacturer.Name}" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена: " Foreground="#777777" FontSize="13" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} руб.'}" Foreground="{StaticResource AccentActionBrush}" FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" Content="Заказать" VerticalAlignment="Center" Click="BtnOrder_Click" Tag="{Binding Id}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>